# ── Solana ────────────────────────────────────────────────────────────────────
# RPC endpoint (use dedicated node for production, e.g. Helius, Triton)
RPC_URL=https://api.mainnet-beta.solana.com

# WebSocket URL (optional, auto-derived from RPC_URL if not set)
# WS_URL=wss://api.mainnet-beta.solana.com

# Program to index
PROGRAM_ID=JUP6LkbZbjS1jKKwapdHNy74zcZ3tLUZoi5QNyVTaV4

# Path to Anchor IDL JSON
IDL_PATH=./idl.json

# ── Database ───────────────────────────────────────────────────────────────────
# postgres (production, default) or sqlite (dev/testing/zero-dep)
DB_TYPE=postgres
DATABASE_URL=postgresql://indexer:indexer@localhost:5432/solana_indexer

# SQLite path (only used when DB_TYPE=sqlite)
# DB_PATH=./indexer.db

# PostgreSQL Docker settings (used by docker-compose --profile postgres)
# POSTGRES_USER=indexer
# POSTGRES_PASSWORD=indexer
# POSTGRES_DB=solana_indexer

# ── API ────────────────────────────────────────────────────────────────────────
PORT=3000

# ── Indexer ────────────────────────────────────────────────────────────────────
# realtime (default) or batch
MODE=realtime

# Polling interval for hybrid mode (ms)
POLL_INTERVAL_MS=5000

# Batch mode: slot range (only used when MODE=batch)
# FROM_SLOT=300000000
# TO_SLOT=310000000

# ── Logging ────────────────────────────────────────────────────────────────────
# debug | info | warn | error
LOG_LEVEL=info
