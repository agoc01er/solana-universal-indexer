# Solana RPC endpoint (use a dedicated node for production)
RPC_URL=https://api.mainnet-beta.solana.com

# Program ID to index
PROGRAM_ID=JUP6LkbZbjS1jKKwapdHNy74zcZ3tLUZoi5QNyVTaV4

# Path to Anchor IDL JSON file
IDL_PATH=./idl.json

# SQLite database path
DB_PATH=./indexer.db

# REST API port
PORT=3000

# Indexing mode: realtime | batch
MODE=realtime

# Polling interval for real-time mode (ms)
POLL_INTERVAL_MS=5000

# Log level: debug | info | warn | error
LOG_LEVEL=info

# Batch mode options (only used when MODE=batch)
# FROM_SLOT=250000000
# TO_SLOT=260000000
