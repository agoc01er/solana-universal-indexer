{
  "name": "solana-universal-indexer",
  "version": "3.0.0",
  "description": "Universal Solana Indexer with IDL-based Dynamic Schema & REST API",
  "main": "dist/index.js",
  "scripts": {
    "setup": "node -e \"const fs=require('fs'); if(!fs.existsSync('.env')){fs.copyFileSync('.env.example','.env');console.log('.env created from .env.example — edit it before running');}else{console.log('.env already exists');}\"",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:prod": "npm run build && npm start",
    "dev": "ts-node src/index.ts",
    "test": "jest --forceExit",
    "test:coverage": "jest --coverage --forceExit"
  },
  "dependencies": {
    "@solana/web3.js": "^1.91.0",
    "better-sqlite3": "^12.8.0",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.25",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.39",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "jest": "^29.7.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ]
  }
}
